# ---------------------------------------------------------------------------
# RPC endpoints (BNB Smart Chain, chainId 56)
# ---------------------------------------------------------------------------
# Public mempool path: a normal BSC RPC. Use a node you trust for fair timing.
PUBLIC_RPC_HTTP=https://bsc-dataseed.bnbchain.org
# WebSocket endpoint used to watch the public pending-tx pool (leak / frontrun detection).
# Optional but strongly recommended — without it we cannot observe mempool first-seen time.
PUBLIC_RPC_WS=

# blink private relay: a private endpoint that accepts a signed raw tx via eth_sendRawTransaction.
BLINK_ENDPOINT=
# Optional auth header for blink, e.g. BLINK_AUTH_HEADER="Authorization" BLINK_AUTH_VALUE="Bearer xxx"
BLINK_AUTH_HEADER=
BLINK_AUTH_VALUE=

# ---------------------------------------------------------------------------
# Sender wallets (SECRETS — never commit; this file is .env.example only)
# Two independent funded wallets. Each must hold TOKEN_IN + BNB for gas,
# and must have approved ROUTER to spend TOKEN_IN (run `npm run prepare:wallets`).
# ---------------------------------------------------------------------------
WALLET_A_PK=
WALLET_B_PK=

# ---------------------------------------------------------------------------
# Swap definition (same swap is sent from both wallets)
# Defaults: sell 0.05 WBNB -> USDT on PancakeSwap V2.
# ---------------------------------------------------------------------------
ROUTER=0x10ED43C718714eb63d5aA57B78B54704E256024E
FACTORY=0xcA143Ce32Fe78f1f7019d7d551a6402fC5350c73
TOKEN_IN=0xBB4CdB9CBd36B01bD1cBaEBF2De08d9173bc095c
TOKEN_OUT=0x55d398326f99059fF775485246999027B3197955
AMOUNT_IN=0.05
SLIPPAGE_BPS=300

# Fair-comparison gas: identical for both txs. If empty, uses network gas price.
GAS_PRICE_GWEI=
GAS_LIMIT=300000

# Reference price (TOKEN_OUT per 1 TOKEN_IN) used to size the backrun opportunity.
# Resolution order: REF_PRICE (if set) > V3 auto-fetch (AUTO_REF_V3) > pre-trade V2 mid.
REF_PRICE=
AUTO_REF_V3=true
V3_FACTORY=0x0BFbCF9fa4f9C56B0F40a671Ad40E0805A091865
V3_FEE_TIERS=100,500,2500,10000

# ---------------------------------------------------------------------------
# Run control
# ---------------------------------------------------------------------------
# DRY_RUN=true builds + signs + analyzes config WITHOUT broadcasting (no funds spent).
DRY_RUN=true
# Number of paired runs and the pause between them.
ITERATIONS=1
INTERVAL_MS=15000
# Swap which wallet uses which path each iteration, to cancel wallet/ordering bias.
ALTERNATE_PATHS=true
# Inclusion wait timeout per run (ms).
INCLUSION_TIMEOUT_MS=60000
# Wait for the thin pool to be arbed back to the V3 reference before the next leg
# (keeps iterations independent; elapsed time ≈ backrun latency).
WAIT_FOR_REVERT=true
REVERT_THRESHOLD_BPS=50
REVERT_TIMEOUT_MS=90000
REVERT_POLL_MS=2000
# Sell the received TOKEN_OUT back to TOKEN_IN each iteration (recycles capital so
# you only need ~1 trade of TOKEN_IN per wallet, not N).
UNWIND=true
# Unwind venue: v2 = same thin pool (re-dislocates it, needs a 2nd revert-wait);
# v3 = deep V3 pool (near-zero impact, leaves the measured V2 pool untouched). Recommended: v3.
UNWIND_VENUE=v3
V3_SWAP_ROUTER=0x1b81D678ffb9C0263b24A97847620C99d213eB14
